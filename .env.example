# === BANDA AI - Variables d'Environnement ===
# ⚠️ NE JAMAIS COMMITTER .env - Copiez ce fichier en .env et remplissez localement

# Base de données (Neon ou Supabase)
DATABASE_URL=postgresql://user:password@host:5432/banda_db?sslmode=require

# Sécurité Modèle IA
BANDA_SECURITY_SALT=CHANGE_ME_VIA_GITHUB_SECRETS

# Paiements Mobile Money (CinetPay Sandbox)
CINETPAY_API_KEY=sandbox_xxxxxxxxxx
CINETPAY_SITE_ID=000000
CINETPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxx

# Stockage Modèles (Cloudflare R2)
R2_ACCESS_KEY=CHANGE_ME
R2_SECRET_KEY=CHANGE_ME
R2_BUCKET_NAME=banda-models
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# App Config
APP_ENV=development
LOG_LEVEL=INFO
